<video
  class="wplayer-video {{ if current }}wplayer-video-current{{ /if }}"
  webkit-playsinline
  playsinline
  {{ if crossOrigin }}crossorigin="{{ crossOrigin }}"{{ /if }}
  {{ if pic }}poster="{{ pic }}"{{ /if }}
  {{ if preload }}preload="{{ preload }}"{{ /if }}
  {{ if url }}
  src="{{ url }}"
  {{ /if }}>
</video>